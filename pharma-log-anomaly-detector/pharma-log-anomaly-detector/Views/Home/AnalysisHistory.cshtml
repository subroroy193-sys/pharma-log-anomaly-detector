@model IEnumerable<pharma_log_anomaly_detector.Models.LogFile>

@{
    ViewData["Title"] = "Analysis History";
}

<h2>Analysis History</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>File Name</th>
            <th>Upload Date</th>
            <th>Records</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var file in Model)
        {
            <tr>
                <td>@file.FileName</td>
                <td>@file.UploadDate</td>
                <td>@file.RecordCount</td>
                <td>@file.AnalysisStatus</td>
                <td>
                    <form asp-action="RunAnalysis" asp-controller="Home" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@file.LogFileId" />
                        <button type="submit"
                                class="btn btn-sm btn-primary"
                            @(file.AnalysisStatus == "Pending" ? "" : "disabled")>
                            Run Analysis
                        </button>
                    </form>

                    <a asp-action="ViewResults"
                       asp-controller="Home"
                       asp-route-id="@file.LogFileId"
                       class="btn btn-sm btn-success @(file.AnalysisStatus == "Completed" ? "" : "disabled")">
                        View Results
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>


