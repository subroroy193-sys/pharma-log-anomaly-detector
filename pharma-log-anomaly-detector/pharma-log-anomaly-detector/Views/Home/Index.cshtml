@{
    ViewData["Title"] = "Dashboard";
}

<div class="text-center mt-5">
    <h1 class="display-4">Pharma Log Anomaly Detector</h1>

    <p class="lead">
        AI-powered log anomaly detection and validation support platform for pharmaceutical computer systems.
    </p>
</div>

<div class="row mt-5">

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">CSV Log Upload</h5>
                <p class="card-text">
                    Upload and validate pharmaceutical system log files for analysis.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">AI Anomaly Detection</h5>
                <p class="card-text">
                    Detect unusual events and patterns using machine learning techniques.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Validation Reporting</h5>
                <p class="card-text">
                    Generate validation-friendly reports and audit-ready findings.
                </p>
            </div>
        </div>
    </div>

</div>


